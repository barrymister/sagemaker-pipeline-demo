# SageMaker Pipeline Demo — Environment Variables
# Copy to .env and fill in your values.

# Set to 'true' for local development via LocalStack, 'false' for real AWS
USE_LOCALSTACK=true

# LocalStack endpoint (only used when USE_LOCALSTACK=true)
AWS_ENDPOINT_URL=http://localhost:4566

# AWS credentials — use 'test'/'test' for LocalStack, real creds for AWS
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# S3 bucket for pipeline data and artifacts
S3_BUCKET=sagemaker-pipeline-demo-data

# SageMaker IAM role ARN (real AWS only)
# Get from: aws iam get-role --role-name SageMakerExecutionRole --query 'Role.Arn'
SAGEMAKER_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/SageMakerExecutionRole

# Instance types (change to ml.m5.xlarge etc. for real training)
TRAINING_INSTANCE_TYPE=ml.t3.medium
INFERENCE_INSTANCE_TYPE=ml.t3.medium
